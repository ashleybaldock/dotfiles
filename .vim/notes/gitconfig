[color "grep"]
  filename      (filename prefix [! -h])
  function      (function name lines [-p])
  lineNumber    (line number prefix [-n])
  column        (column number prefix [--column])
  match         тОЫmatching text, both or only inтАжтОЮ
  matchContext  тОЬ              тАжcontext lines   тОЯ
  matchSelected тОЭ              тАжselected lines  тОа ╩Ея╕П also used for git-log
  selected      (selected lines)                  тОн [--grep, --author, --committer]
  context       (context lines [-A, -B, -C])
  separator     (between fields (:, -, and =) between hunks (--)

[color "push"]
  error         (push errors)

[color "transport"]
  rejected      (push rejected)

[color "branch"]
  current       (the current branch)
  local         (a local branch)
  remote        (a remote-tracking branch in refs/remotes/)
  upstream      (upstream tracking branch)
  plain         (other refs)


[color "remote"]
  hint
  warning
  success
  error


diff
--output-indicator-new=+
--output-indicator-old=-
--output-indicator-context= 


[color "diff"]
  meta          (metainformation)
  commit        (commit headers)
  whitespace    (highlighting whitespace errors)

  frag          (hunk header)
  func          (function in hunk header)

  context       (context text - plain is a historical synonym)
  contextDimmed
  contextBold

  new           (added lines)
  newDimmed
  newBold       (see git-range-diff(1))

  newMoved                  (added lines)
  newMovedDimmed
  newMovedAlternative
  newMovedAlternativeDimmed (See <mode> of --color-moved in git-diff(1) for details)

  old                       (removed lines)
  oldDimmed
  oldBold

  oldMoved                  (deleted lines)
  oldMovedDimmed
  oldMovedAlternative
  oldMovedAlternativeDimmed




color.status.<slot>
[color "status"]
  header        (the header text of the status message)
  added
  updated       (files which are added but not committed)
  changed       (files which are changed but not added in the index)
  untracked     (files which are not tracked by Git)
  branch (the current branch)
  nobranch      (the color the no branch warning is shown in defaulting to red)
  localBranch
  remoteBranch (the local and remote branch names respectively when branch and tracking information is displayed in the status short-format)
  unmerged     (files which have unmerged changes).


