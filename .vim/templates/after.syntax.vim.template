"
" Syntax highlighting extensions for '%FILE%' files
"
" :au BufWritePost <buffer> syn on
"
" Related:
"     $VIMHOME/ftplugin/%FILE:LC%.vim
"     $VIMHOME/after/ftplugin/%FILE:LC%.vim
"     $VIMRUNTIME/ftplugin/%FILE:LC%.vim
"     $VIMRUNTIME/syntax/%FILE:LC%.vim

let s:cpo_save = &cpo
set cpo&vim


syn match %CUR%


let &cpo = s:cpo_save
unlet s:cpo_save

